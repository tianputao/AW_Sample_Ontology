<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:aw="http://tarhone.com/ontology/adventrueworks#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#orderDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">order date</rdfs:label>
    <rdfs:label xml:lang="zh">下单日期</rdfs:label>
    <rdfs:comment xml:lang="en">Date the order was placed.</rdfs:comment>
    <rdfs:comment xml:lang="zh">下单日期。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>
  <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#status_unknown">
    <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#OrderStatus"/>
    <rdfs:label xml:lang="en">Unknown</rdfs:label>
    <rdfs:label xml:lang="zh">未知</rdfs:label>
  </owl:NamedIndividual>
  <owl:Class rdf:about="http://tarhone.com/ontology/adventrueworks#HighValueOrder">
    <rdfs:label xml:lang="en">High-Value Order</rdfs:label>
    <rdfs:label xml:lang="zh">高价值订单</rdfs:label>
    <rdfs:comment xml:lang="en">An order whose :totalDue is &gt;= 500.0. Defined class.</rdfs:comment>
    <rdfs:comment xml:lang="zh">订单 :totalDue &gt;= 500.0 的高价值订单。等价类。</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="N296950520b48433bb30c1ab95bcc71ec">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
          <owl:Restriction rdf:nodeID="N15394a057d9f47ddb433c1395c0fa0a7">
            <owl:onProperty>
              <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#totalDue">
                <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
                <rdfs:label xml:lang="en">total due</rdfs:label>
                <rdfs:label xml:lang="zh">应付总额</rdfs:label>
                <rdfs:comment xml:lang="en">Grand total due in USD.</rdfs:comment>
                <rdfs:comment xml:lang="zh">应付总额（美元）。</rdfs:comment>
                <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
                <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <aw:unit xml:lang="en">USD</aw:unit>
              </owl:DatatypeProperty>
            </owl:onProperty>
            <owl:someValuesFrom>
              <rdfs:Datatype rdf:nodeID="N4afb1fa6b3c64afdb562e8e9c07d949c">
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                  <rdf:Description rdf:nodeID="N4a5dc1c30ae24e9eb39ba90b47203626">
                    <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">500.0</xsd:minInclusive>
                  </rdf:Description>
                </owl:withRestrictions>
              </rdfs:Datatype>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://tarhone.com/ontology/adventrueworks#hasParentCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:label xml:lang="en">has parent category</rdfs:label>
    <rdfs:label xml:lang="zh">父类目</rdfs:label>
    <rdfs:comment xml:lang="en">The immediate parent in the ProductCategory hierarchy.</rdfs:comment>
    <rdfs:comment xml:lang="zh">产品类目层次的直接父节点。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
    <rdfs:range rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#nameSuffix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">name suffix</rdfs:label>
    <rdfs:label xml:lang="zh">姓名后缀</rdfs:label>
    <rdfs:comment xml:lang="en">Suffix such as Jr., Sr., II.</rdfs:comment>
    <rdfs:comment xml:lang="zh">姓名后缀（Jr./Sr.）。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#revisionNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">revision number</rdfs:label>
    <rdfs:label xml:lang="zh">版本号</rdfs:label>
    <rdfs:comment xml:lang="en">Sales order revision number.</rdfs:comment>
    <rdfs:comment xml:lang="zh">销售订单版本号。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#productId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">product id</rdfs:label>
    <rdfs:label xml:lang="zh">产品编号</rdfs:label>
    <rdfs:comment xml:lang="en">Original AdventureWorks ProductID.</rdfs:comment>
    <rdfs:comment xml:lang="zh">原始 ProductID。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Product"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:Ontology rdf:about="http://tarhone.com/ontology/adventrueworks">
    <rdfs:label xml:lang="en">AdventureWorks Sales Ontology</rdfs:label>
    <rdfs:label xml:lang="zh">AdventureWorks 销售本体</rdfs:label>
    <rdfs:comment xml:lang="en">An OWL 2 DL ontology generated from the AdventureWorks Silver layer (ai_data_insight.silver). Includes Customers, Addresses, Sales Orders, Order Lines, Products, and a recursive Product Category hierarchy. Authored as a learning demo for Protégé.</rdfs:comment>
    <rdfs:comment xml:lang="zh">基于 AdventureWorks Silver 数据层（ai_data_insight.silver）自动生成的 OWL 2 DL 本体，包含客户、地址、销售订单、订单明细、产品以及递归产品类目层次结构。用于 Protégé 入门演示。</rdfs:comment>
    <owl:versionInfo>1.0.0</owl:versionInfo>
  </owl:Ontology>
  <owl:ObjectProperty rdf:about="http://tarhone.com/ontology/adventrueworks#hasColor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has color</rdfs:label>
    <rdfs:label xml:lang="zh">颜色</rdfs:label>
    <rdfs:comment xml:lang="en">Color of a Product.</rdfs:comment>
    <rdfs:comment xml:lang="zh">产品的颜色。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Product"/>
    <rdfs:range rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductColor"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="http://tarhone.com/ontology/adventrueworks#Fenders">
    <rdfs:label xml:lang="en">Fenders</rdfs:label>
    <rdfs:label xml:lang="zh">Fenders</rdfs:label>
    <rdfs:comment xml:lang="en">AdventureWorks product category: Fenders.</rdfs:comment>
    <rdfs:comment xml:lang="zh">AdventureWorks 产品类目：Fenders。</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://tarhone.com/ontology/adventrueworks#Accessories"/>
  </owl:Class>
  <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#category_14">
    <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
    <rdfs:label xml:lang="en">Forks</rdfs:label>
    <rdfs:label xml:lang="zh">Forks</rdfs:label>
    <aw:categoryId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14</aw:categoryId>
    <aw:categoryName>Forks</aw:categoryName>
    <aw:hasParentCategory>
      <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#category_2">
        <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
        <rdfs:label xml:lang="en">Components</rdfs:label>
        <rdfs:label xml:lang="zh">Components</rdfs:label>
        <aw:categoryId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</aw:categoryId>
        <aw:categoryName>Components</aw:categoryName>
      </owl:NamedIndividual>
    </aw:hasParentCategory>
  </owl:NamedIndividual>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#categoryName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">category name</rdfs:label>
    <rdfs:label xml:lang="zh">类目名</rdfs:label>
    <rdfs:comment xml:lang="en">Display name of the category.</rdfs:comment>
    <rdfs:comment xml:lang="zh">类目显示名。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#customerId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">customer id</rdfs:label>
    <rdfs:label xml:lang="zh">客户编号</rdfs:label>
    <rdfs:comment xml:lang="en">Original AdventureWorks CustomerID.</rdfs:comment>
    <rdfs:comment xml:lang="zh">AdventureWorks 原始 CustomerID。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#status_backOrdered">
    <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#OrderStatus"/>
    <rdfs:label xml:lang="en">BackOrdered</rdfs:label>
    <rdfs:label xml:lang="zh">缺货延期</rdfs:label>
    <rdfs:comment xml:lang="en">Order status code 3 = BackOrdered.</rdfs:comment>
    <rdfs:comment xml:lang="zh">订单状态码 3 = 缺货延期。</rdfs:comment>
    <aw:statusCode rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</aw:statusCode>
  </owl:NamedIndividual>
  <owl:Class rdf:about="http://tarhone.com/ontology/adventrueworks#IndividualCustomer">
    <rdfs:label xml:lang="en">Individual Customer</rdfs:label>
    <rdfs:label xml:lang="zh">个人客户</rdfs:label>
    <rdfs:comment xml:lang="en">A customer that is a private individual (no associated company name).</rdfs:comment>
    <rdfs:comment xml:lang="zh">无所属公司的个人客户。</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://tarhone.com/ontology/adventrueworks#Customer"/>
    <owl:disjointWith rdf:resource="http://tarhone.com/ontology/adventrueworks#BusinessCustomer"/>
    <owl:equivalentClass>
      <owl:Class rdf:nodeID="Nd760704729ca40099ef28417adfe9661">
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://tarhone.com/ontology/adventrueworks#Customer"/>
          <owl:Class rdf:nodeID="N0f56d330d0b140de9f4b2758b8e6b30c">
            <owl:complementOf>
              <owl:Restriction rdf:nodeID="N359e08336edb42dbbeb8b13f2c9668f0">
                <owl:onProperty rdf:resource="http://tarhone.com/ontology/adventrueworks#companyName"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
              </owl:Restriction>
            </owl:complementOf>
          </owl:Class>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#categoryId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">category id</rdfs:label>
    <rdfs:label xml:lang="zh">类目编号</rdfs:label>
    <rdfs:comment xml:lang="en">Original AdventureWorks ProductCategoryID.</rdfs:comment>
    <rdfs:comment xml:lang="zh">原始 ProductCategoryID。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="http://tarhone.com/ontology/adventrueworks#Forks">
    <rdfs:label xml:lang="en">Forks</rdfs:label>
    <rdfs:label xml:lang="zh">Forks</rdfs:label>
    <rdfs:comment xml:lang="en">AdventureWorks product category: Forks.</rdfs:comment>
    <rdfs:comment xml:lang="zh">AdventureWorks 产品类目：Forks。</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://tarhone.com/ontology/adventrueworks#Components"/>
  </owl:Class>
  <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#customer_2">
    <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#Customer"/>
    <rdfs:label xml:lang="en">Keith Harris</rdfs:label>
    <rdfs:label xml:lang="zh">Keith Harris</rdfs:label>
    <aw:customerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</aw:customerId>
    <aw:firstName>Keith</aw:firstName>
    <aw:lastName>Harris</aw:lastName>
    <aw:companyName>Progressive Sports</aw:companyName>
    <aw:emailAddress>keith0@adventure-works.com</aw:emailAddress>
    <aw:phone>170-555-0127</aw:phone>
    <aw:hasTitle>
      <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#title_mr">
        <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#PersonTitle"/>
        <rdfs:label xml:lang="en">Mr.</rdfs:label>
        <rdfs:label xml:lang="zh">先生</rdfs:label>
      </owl:NamedIndividual>
    </aw:hasTitle>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#atype_shipping">
    <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#AddressType"/>
    <rdfs:label xml:lang="en">Shipping</rdfs:label>
    <rdfs:label xml:lang="zh">收货地址</rdfs:label>
  </owl:NamedIndividual>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#salesOrderNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">sales order number</rdfs:label>
    <rdfs:label xml:lang="zh">订单号</rdfs:label>
    <rdfs:comment xml:lang="en">Business sales order number (e.g. SO71774).</rdfs:comment>
    <rdfs:comment xml:lang="zh">业务订单号（如 SO71774）。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="http://tarhone.com/ontology/adventrueworks#Headsets">
    <rdfs:label xml:lang="en">Headsets</rdfs:label>
    <rdfs:label xml:lang="zh">Headsets</rdfs:label>
    <rdfs:comment xml:lang="en">AdventureWorks product category: Headsets.</rdfs:comment>
    <rdfs:comment xml:lang="zh">AdventureWorks 产品类目：Headsets。</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://tarhone.com/ontology/adventrueworks#Components"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://tarhone.com/ontology/adventrueworks#containsProduct">
    <rdfs:label xml:lang="en">contains product</rdfs:label>
    <rdfs:label xml:lang="zh">包含产品</rdfs:label>
    <rdfs:comment xml:lang="en">Inverse of :inCategory.</rdfs:comment>
    <rdfs:comment xml:lang="zh">:inCategory 的逆属性。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
    <rdfs:range rdf:resource="http://tarhone.com/ontology/adventrueworks#Product"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="http://tarhone.com/ontology/adventrueworks#inCategory">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label xml:lang="en">in category</rdfs:label>
        <rdfs:label xml:lang="zh">属于类目</rdfs:label>
        <rdfs:comment xml:lang="en">Direct ProductCategory of this product.</rdfs:comment>
        <rdfs:comment xml:lang="zh">此产品所属的（最细粒度）产品类目。</rdfs:comment>
        <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Product"/>
        <rdfs:range rdf:resource="http://tarhone.com/ontology/adventrueworks#ProductCategory"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:AnnotationProperty rdf:about="http://tarhone.com/ontology/adventrueworks#unit">
    <rdfs:label xml:lang="en">unit</rdfs:label>
    <rdfs:label xml:lang="zh">单位</rdfs:label>
    <rdfs:comment xml:lang="en">Free-text unit-of-measure annotation for data properties.</rdfs:comment>
  </owl:AnnotationProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#taxAmt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">tax amount</rdfs:label>
    <rdfs:label xml:lang="zh">税额</rdfs:label>
    <rdfs:comment xml:lang="en">Tax amount in USD.</rdfs:comment>
    <rdfs:comment xml:lang="zh">税额（美元）。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <aw:unit xml:lang="en">USD</aw:unit>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#emailAddress">
