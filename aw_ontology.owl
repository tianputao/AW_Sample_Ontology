    <rdfs:comment xml:lang="zh">客户电子邮箱。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#freight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">freight</rdfs:label>
    <rdfs:label xml:lang="zh">运费</rdfs:label>
    <rdfs:comment xml:lang="en">Freight charge in USD.</rdfs:comment>
    <rdfs:comment xml:lang="zh">运费（美元）。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <aw:unit xml:lang="en">USD</aw:unit>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#middleName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">middle name</rdfs:label>
    <rdfs:label xml:lang="zh">中间名</rdfs:label>
    <rdfs:comment xml:lang="en">Middle name (if any).</rdfs:comment>
    <rdfs:comment xml:lang="zh">中间名（如有）。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#Customer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#accountNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">account number</rdfs:label>
    <rdfs:label xml:lang="zh">账户号</rdfs:label>
    <rdfs:comment xml:lang="en">Customer account number.</rdfs:comment>
    <rdfs:comment xml:lang="zh">客户账户号。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://tarhone.com/ontology/adventrueworks#lineTotal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">line total</rdfs:label>
    <rdfs:label xml:lang="zh">行小计</rdfs:label>
    <rdfs:comment xml:lang="en">Line total in USD.</rdfs:comment>
    <rdfs:comment xml:lang="zh">行小计（美元）。</rdfs:comment>
    <rdfs:domain rdf:resource="http://tarhone.com/ontology/adventrueworks#SalesOrderLine"/>
