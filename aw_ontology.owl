    <aw:unit xml:lang="en">USD</aw:unit>
  </owl:DatatypeProperty>
  <owl:NamedIndividual rdf:about="http://tarhone.com/ontology/adventrueworks#ship_unknown">
    <rdf:type rdf:resource="http://tarhone.com/ontology/adventrueworks#ShipMethod"/>
    <rdfs:label xml:lang="en">Unknown</rdfs:label>
